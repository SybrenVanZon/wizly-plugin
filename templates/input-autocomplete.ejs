<% if (typeof rowId !== 'undefined' && rowId) { %>
    @if (mg.isRowInRowEditing(row)) {
<% } %>

<mat-form-field
    <% if (attrVisible) { %>[style.visibility]="<%= attrVisible %>"<% } %>
    <% if (attrTooltip) { %>[matTooltip]="<%= attrTooltip %>"<% } %>
>
    <% if (typeof rowId === 'undefined' || !rowId) { %>
        <% if (getLabel(magic)) { %>
        <mat-label><%= getLabel(magic) %></mat-label>
        <% } %>
    <% } %>

    <input
        matInput
        type="<%= inputType %>"
        [magic]="<%= magic %>"
        <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %>
        <% if (attrPlaceholder) { %>[placeholder]="<%= attrPlaceholder %>"<% } %>
        [formControlName]="<%= magic %>"
        [matAutocomplete]="auto_<%= magic.replace('mgc.', '') %>"
        <% if (attrDisabled) { %>[disabled]="<%= attrDisabled %>"<% } %>
        mgFormat
        <% if (attrRequired) { %>[required]="<%= attrRequired %>"<% } %>
    >
    <mat-autocomplete #auto_<%= magic.replace('mgc.', '') %>="matAutocomplete">
        @for (option of mg.getFilteredList(<%= magic %><% if (typeof rowId !== 'undefined' && rowId) { %>, <%= rowId %><% } %>); track option) {
            <mat-option [value]="option.displayValue">{{option.displayValue}}</mat-option>
        }
    </mat-autocomplete>

    <% if (zoom) { %>
    <button
        mat-icon-button
        matSuffix
        color="primary"
        [magic]="<%= magic %>"
        <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %>
        (click)="onZoom(<%= magic %><% if (typeof rowId !== 'undefined' && rowId) { %>, <%= rowId %><% } %>)"
        <% if (attrDisabled) { %>[disabled]="<%= attrDisabled %>"<% } %>
    >
        <mat-icon><%= zoomIcon %></mat-icon>
    </button>
    <% } %>

    <mgError [magic]="<%= magic %>" <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %> mgError></mgError>
</mat-form-field>

<% if (typeof rowId !== 'undefined' && rowId) { %>
    } @else {
        <%- include('partials/table-readonly') %>
    }
<% } %>
