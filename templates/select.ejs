<% } %>

<mat-form-field
    <% if (attrVisible) { %>[style.visibility]="<%= attrVisible %>"<% } %>
    <% if (attrTooltip) { %>[matTooltip]="<%= attrTooltip %>"<% } %>
>
    <% if (typeof rowId === 'undefined' || !rowId) { %>
        <% if (getLabel(magic)) { %>
        <mat-label><%= getLabel(magic) %></mat-label>
        <% } %>
    <% } %>
    <mat-select
        [magic]="<%= magic %>"
        <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %>
        [formControlName]="<%= magic %>"
        <% if (attrRequired === 'true') { %>required<% } else if (attrRequired) { %>[required]="<%= attrRequired %>"<% } %>
        <% if (attrPlaceholder) { %>placeholder="<%= attrPlaceholder %>"<% } %>
        <% if (attrDisabled) { %>[disabled]="<%= attrDisabled %>"<% } %>
    >
        @for (o of mg.getItemListValues(<%= magic %><% if (typeof rowId !== 'undefined' && rowId) { %>, <%= rowId %><% } %>); track o) {
            <mat-option [value]="o.index">
                {{o.displayValue}}
            </mat-option>
        }
    </mat-select>
</mat-form-field>
<mgError [magic]="<%= magic %>" <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %>> </mgError>

<% if (typeof rowId !== 'undefined' && rowId) { %>
    } @else {
        <%- include('partials/table-readonly') %>
    }
<% } %>
