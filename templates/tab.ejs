<mat-tab-group
    [magic]="<%= magic %>"
    (selectedTabChange)="task.mgOnTabSelectionChanged(<%= magic %>, $event.index)"
    [selectedIndex]="mg.getTabSelectedIndex(<%= magic %>)"
    <% if (attrVisible) { %>[style.visibility]="<%= attrVisible %>"<% } %>
    <% if (attrTooltip) { %>[matTooltip]="<%= attrTooltip %>"<% } %>
>
<%
    const tabName = magic.replace(/^mgc\./, '');
    const tabPages = tabPageContent && tabPageContent[tabName];
    if (tabPages) {
        for (let i = 1; i < tabPages.length; i++) {
%>
    <mat-tab [label]="mg.getTabpageText(<%= magic %>, <%= i %>)">
        <%- tabPages[i] %>
    </mat-tab>
<%  }
    } else {
%>
    @for(o of mg.getItemListValues(<%= magic %>); track o) {
        <mat-tab
            [label]="mg.getTabpageText(<%= magic %>, o.index)"
        >
        </mat-tab>
    }
<% } %>
</mat-tab-group>
