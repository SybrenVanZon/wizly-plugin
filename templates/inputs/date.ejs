<input
    matInput
    [matDatepicker]="picker_<%= magic.replace('mgc.', '') %>"
    [magic]="<%= magic %>"
    <% if (typeof rowId !== 'undefined' && rowId) { %>[rowId]="<%= rowId %>"<% } %>
    [formControlName]="<%= magic %>"
    <% if (attrPlaceholder) { %>[placeholder]="<%= attrPlaceholder %>"<% } %>
    mgFormat
    <% if (attrRequired) { %>[required]="<%= attrRequired %>"<% } %>
    <% if (attrDisabled) { %>[disabled]="<%= attrDisabled %>"<% } %>
>
@if (!mg.checkIsReadOnly(<%= magic %>)) {
    <mat-datepicker-toggle matSuffix [for]="picker_<%= magic.replace('mgc.', '') %>">
    </mat-datepicker-toggle>
}
<mat-datepicker #picker_<%= magic.replace('mgc.', '') %>></mat-datepicker>
